# Environment
ENVIRONMENT=development  # development or production

# API Configuration
ACCESS_TOKEN_SECURITY_KEY=<your-secret-key-change-this>
ACCESS_TOKEN_EXPIRE_MINUTES=10080  # 7 days

# Database Configuration
POSTGRES_SERVER=db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=chat_db

# CORS
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# DESCOPE - Unset Project ID if not using Descope
DESCOPE_PROJECT_ID=

# Required: Anthropic API key for the agent model (anthropic/claude-sonnet-4-6)
ANTHROPIC_API_KEY=<your-anthropic-key>

# MCP Servers needing keys

## Log Level for MCP Servers
MCP_SERVER_LOG_LEVEL=debug

## Required: Brave Search API key for the mcp-server-brave-search
BRAVE_API_KEY=<your-brave-key>